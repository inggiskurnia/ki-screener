{
  "name": "idx-telegram-alerts",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "smoke": "tsx src/smoke.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "better-sqlite3": "11.8.1",
    "cheerio": "1.0.0",
    "playwright": "1.61.1"
  },
  "devDependencies": {
    "@eslint/js": "9.39.5",
    "@types/better-sqlite3": "7.6.12",
    "@types/node": "22.13.10",
    "eslint": "9.39.5",
    "tsx": "4.19.3",
    "typescript": "5.8.2",
    "typescript-eslint": "8.26.0",
    "vitest": "3.2.7"
  }
}
